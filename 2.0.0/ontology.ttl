                                                      <http://purl.obolibrary.org/obo/IAO_0000115> "A place that refers to a geographical territory forming part of a country."@en ;
                                                      rdfs:comment "A federal state where the thing is located."@en ;
                                                      rdfs:isDefinedBy <https://nfdi.fiz-karlsruhe.de/ontology/2.0.0> ;
                                                      rdfs:label "federal state"@en ;
                                                      <http://www.w3.org/2004/02/skos/core#example> "Sachsen, Berlin"@de .


