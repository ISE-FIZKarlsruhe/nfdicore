# Class: :NFDI_0001101 (added value textual entity)

AnnotationAssertion(rdfs:label :NFDI_0001101 "added value textual entity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001101 "An added value textual entity is a textual entity that describes the achievements, benefits, or additional value generated by a project, service, or initiative, highlighting its impact, improvements, or contributions.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001101 "In responce to competency questions like what are the added values of project X1 or service X2.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001101 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001101 <http://purl.obolibrary.org/obo/IAO_0000300>)

