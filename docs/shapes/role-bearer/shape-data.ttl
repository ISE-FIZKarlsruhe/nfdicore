@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix ex:    <http://example.org/> .

#
#  Example: A researcher bears a "contributor role" which is realized in
#  a data curation process.
#

ex:contributor_role_1
    a <http://purl.obolibrary.org/obo/BFO_0000023> ;                # Role
    a <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000118> ;       # contributor role
    <http://purl.obolibrary.org/obo/RO_0000081> ex:researcher_1 ;   # role_of
    <http://purl.obolibrary.org/obo/BFO_0000054> ex:curation_process_1 .  # realized_in

ex:researcher_1
    a <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000001> ;       # Person
    rdfs:label "Dr. Example Researcher" .

ex:curation_process_1
    a <http://purl.obolibrary.org/obo/BFO_0000015> ;                # Process
    rdfs:label "Data curation process" .
