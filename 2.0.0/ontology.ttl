###  https://nfdi.fiz-karlsruhe.de/ontology/License
<https://nfdi.fiz-karlsruhe.de/ontology/License> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ;
                                                 <http://purl.obolibrary.org/obo/IAO_0000115> "An information content entity that refers to a legal instrument (usually by way of contract law, with or without printed material) governing the use or redistribution of the resource containing the licence."@en ;
                                                 rdfs:comment "A document that provides legal guidelines for the use of a resource, e.g. a software."@en ;
                                                 rdfs:isDefinedBy <https://nfdi.fiz-karlsruhe.de/ontology/2.0.0> ;
                                                 rdfs:label "license"@en ;
