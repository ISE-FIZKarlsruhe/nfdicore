AnnotationAssertion(rdfs:label :NFDI_0001096 "consortium partner role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001096 "An agent role that exresses that an organization inhering that role actively collaborates within a consortium, contributing expertise, resources, or infrastructure to support shared research, development, or innovation goals."@en)
SubClassOf(:NFDI_0001096 :NFDI_0000229)

