        <rdfs:comment xml:lang="en">The property is a relationship between a thing and a url associated with the thing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">url</rdfs:label>
    </owl:ObjectProperty>
    


