    <owl:ObjectProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/contactPoint">
        <owl:inverseOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/contactPointOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/Project"/>
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/Resource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Agent"/>
        <rdfs:comment xml:lang="en">The property is a relationship between a resource and a contact point.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">contact point</rdfs:label>
