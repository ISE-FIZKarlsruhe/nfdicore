AnnotationAssertion(rdfs:label :NFDI_0001001 "citation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001001 "A textual entity intended to identify a particular publication.")
SubClassOf(:NFDI_0001001 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001002 (workflow specification)

AnnotationAssertion(rdfs:label :NFDI_0001002 "workflow specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001002 "A plan specification that defines the sequence, dependencies, roles, and conditions governing the execution of tasks and processes within a workflow, ensuring structured and efficient task coordination, automation, and completion.")
SubClassOf(:NFDI_0001002 <http://purl.obolibrary.org/obo/IAO_0000104>)

# Class: :NFDI_0001004 (project proposal)

AnnotationAssertion(rdfs:label :NFDI_0001004 "project proposal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001004 "A project proposal is a detailed document that outlines the objectives, scope, requirements, and deliverables of a project. It serves as a blueprint for all stakeholders, ensuring everyone understands what needs to be accomplished."@en)
SubClassOf(:NFDI_0001004 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000310> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000136> :NFDI_0000002)))

# Class: :NFDI_0001009 (GND identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001009 "Gemeinsame Normdatei"@de)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001009 "Integrated Authority File"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001009 "https://www.dnb.de/EN/Professionell/Standardisierung/GND/gnd_node.html")
AnnotationAssertion(rdfs:label :NFDI_0001009 "GND identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001009 "A centrally registered identifier that is issued by the German National Library. The Integrated Authority File (GND) is facilitates the collaborative use and administration of authority data. These authority data represent and describe entities, i.e. persons, corporate bodies, conferences and events, geographic entities, topics and works relating to cultural and academic collections."@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0001009 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001009 "GND"@en)
SubClassOf(:NFDI_0001009 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001010 (VIAF identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001010 "Integrated Authority File"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001010 "Virtual International Authority File"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001010 "https://viaf.org/en")
AnnotationAssertion(rdfs:label :NFDI_0001010 "VIAF identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001010 "The centrally registered identifier VIAF (Virtual International Authority File) is an international authority file that links and integrates authority records from multiple national libraries and other organizations. It provides a unique identifier for authors, creators, and entities, facilitating better data sharing and cataloging across institutions."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001010 "https://viaf.org/en/viaf/137346469")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001010 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001010 "VIAF"@en)
SubClassOf(:NFDI_0001010 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001011 (GeoNames identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001011 "GeoNames"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001011 "https://www.geonames.org/")
AnnotationAssertion(rdfs:label :NFDI_0001011 "GeoNames identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001011 "GeoNames is a geographical database that provides information on places, including names, coordinates, and administrative divisions. It integrates data from multiple sources and is widely used for geolocation, mapping, and geographic information systems (GIS)."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001011 "https://www.geonames.org/2950159")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001011 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
SubClassOf(:NFDI_0001011 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001012 (Wikidata identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001012 "Wikidata"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001012 "https://www.wikidata.org/")
AnnotationAssertion(rdfs:label :NFDI_0001012 "Wikidata identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001012 "Wikidata is maintained by the Wikimedia Foundation and serves as a central repository for structured data used by Wikipedia, Wikimedia projects, and external applications."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001012 "https://www.wikidata.org/wiki/Q1388737")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001012 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
SubClassOf(:NFDI_0001012 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001013 (ROR identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001013 "https://ror.org/")
AnnotationAssertion(rdfs:label :NFDI_0001013 "ROR identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001013 "ROR (Research Organization Registry) is a global, open, and community-driven registry of research organizations. It provides unique identifiers for institutions involved in research, enabling better data integration, disambiguation, and interoperability across scholarly communication systems."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001013 "https://ror.org/01kdxra28")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001013 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001013 "ROR"@en)
SubClassOf(:NFDI_0001013 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001014 (ISIL identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001014 "International Standard Identifier for Libraries and Related Organizations"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001014 "https://sigel.staatsbibliothek-berlin.de/")
AnnotationAssertion(rdfs:label :NFDI_0001014 "ISIL identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001014 "ISIL (International Standard Identifier for Libraries and Related Organizations) is a globally recognized identifier system used to uniquely identify libraries, archives, museums, and other cultural institutions. It facilitates resource sharing, cataloging, and data exchange across institutions and countries."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001014 "https://ld.zdb-services.de/resource/organisations/DE-4153")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001014 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001014 "ISIL"@en)
SubClassOf(:NFDI_0001014 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001015 (FactGrid identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001015 "FactGrid"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001015 "https://database.factgrid.de/")
AnnotationAssertion(rdfs:label :NFDI_0001015 "FactGrid identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001015 "FactGrid is a collaborative, structured knowledge database designed for historical research. It operates on Wikibase and focuses on documenting historical entities, events, and relationships."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001015 "https://database.factgrid.de/entity/Q595")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001015 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
SubClassOf(:NFDI_0001015 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001016 (RISM identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001016 "Répertoire International des Sources Musicales"@fr)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001016 "https://rism.info/")
AnnotationAssertion(rdfs:label :NFDI_0001016 "RISM identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001016 "RISM (Répertoire International des Sources Musicales) is an international catalog of historical music sources, including manuscripts, printed music, and treatises. It provides unique identifiers and bibliographic data to support music research and documentation."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001016 "https://rism.online/sources/201001959/")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001016 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001016 "RISM"@en)
SubClassOf(:NFDI_0001016 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001017 (export format specification)

AnnotationAssertion(rdfs:label :NFDI_0001017 "export format specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001017 "A directive information entity that defines the structural, syntactic, and encoding rules for representing data when it is exported from a system."@en)
SubClassOf(:NFDI_0001017 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000033> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> :NFDI_0000148)))

# Class: :NFDI_0001018 (textual description)

AnnotationAssertion(rdfs:label :NFDI_0001018 "textual description"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001018 "A textual entity that describe some resource."@en)
SubClassOf(:NFDI_0001018 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001019 (title)

AnnotationAssertion(rdfs:label :NFDI_0001019 "title"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001019 "A textual entity that denotes some resource."@en)
SubClassOf(:NFDI_0001019 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001020 (act of foundation)

AnnotationAssertion(rdfs:label :NFDI_0001020 "act of foundation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001020 "The act of foundation refers to the formal establishment or creation of an institution, organization, or entity, typically through a legal, administrative, or ceremonial process."@en)
SubClassOf(:NFDI_0001020 ObjectIntersectionOf(:NFDI_0000131 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> <http://purl.obolibrary.org/obo/OBI_0000245>)))

# Class: :NFDI_0001021 (act of dissolution)

AnnotationAssertion(rdfs:label :NFDI_0001021 "act of dissolution"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001021 "The act of dissolution refers to a formal legal or administrative event that officially terminates or dissolves an entity, relationship, or agreement."@en)
SubClassOf(:NFDI_0001021 ObjectIntersectionOf(:NFDI_0000131 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> <http://purl.obolibrary.org/obo/OBI_0000245>)))

# Class: :NFDI_0001022 (ontology namespace)

AnnotationAssertion(rdfs:label :NFDI_0001022 "ontology namespace"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001022 "A namespace refers to a distinct, unique identifier that is used to distinguish concepts and entities within an ontology from those in other ontologies or systems. It's typically represented as a URL or URI (Uniform Resource Identifier) and ensures that each element within the ontology has a globally unique reference."@en)
SubClassOf(:NFDI_0001022 <http://purl.obolibrary.org/obo/IAO_0000027>)

# Class: :NFDI_0001025 (creation process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001025 <http://purl.obolibrary.org/obo/NCIT_C42620>)
AnnotationAssertion(rdfs:label :NFDI_0001025 "creation process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001025 "A process by which something is brought into existence; having been brought into existence."@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0001025 "issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/95")
SubClassOf(:NFDI_0001025 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0001026 (creator role)

AnnotationAssertion(rdfs:label :NFDI_0001026 "creator role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001026 "A role inherent in an agent that originates, develops, or produces a work, product, or idea."@en)
SubClassOf(:NFDI_0001026 :NFDI_0000229)

# Class: :NFDI_0001029 (document part)

AnnotationAssertion(rdfs:isDefinedBy :NFDI_0001029 "http://purl.obolibrary.org/obo/IAO_0000314")
AnnotationAssertion(rdfs:label :NFDI_0001029 "document part"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001029 "An information content entity that is part of a document.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001029 "An abstract, introduction, method or results section.")
SubClassOf(:NFDI_0001029 <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: :NFDI_0001030 (author list)

AnnotationAssertion(rdfs:isDefinedBy :NFDI_0001030 "http://purl.obolibrary.org/obo/IAO_0000321")
AnnotationAssertion(rdfs:label :NFDI_0001030 "author list"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001030 "A part of a document that enumerates the authors of the document")
SubClassOf(:NFDI_0001030 :NFDI_0001029)

# Class: :NFDI_0001031 (contributor list)

AnnotationAssertion(rdfs:label :NFDI_0001031 "contributor list"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001031 "A part of a document that enumerates the contributors of the document")
SubClassOf(:NFDI_0001031 :NFDI_0001029)

# Class: :NFDI_0001032 (creator list)

AnnotationAssertion(rdfs:label :NFDI_0001032 "creator list"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001032 "A part of a document that enumerates the creators of the document")
SubClassOf(:NFDI_0001032 :NFDI_0001029)

# Class: :NFDI_0001033 (institution list)

AnnotationAssertion(rdfs:isDefinedBy :NFDI_0001033 "http://purl.obolibrary.org/obo/IAO_0000322")
AnnotationAssertion(rdfs:label :NFDI_0001033 "institution list"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001033 "A part of a document that has parts that are institution identifications associated with the authors of the document")
SubClassOf(:NFDI_0001033 :NFDI_0001029)

# Class: :NFDI_0001034 (uniform resource locator)

AnnotationAssertion(rdfs:label :NFDI_0001034 "uniform resource locator"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0001034 "http://purl.allotrope.org/ontologies/result#AFR_0001068")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001034 "A Uniform Resource Locator (URL), colloquially termed a web address, is a reference to a web resource that specifies its location on a computer network and a mechanism for retrieving it. [Wikipedia]"@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0001034 "issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/95")
SubClassOf(:NFDI_0001034 <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: :NFDI_0001035 (work package textual entity)

AnnotationAssertion(rdfs:label :NFDI_0001035 "work package textual entity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001035 "A work package textual entity is a textual entity that describes a structured unit of work within a project, outlining specific tasks, objectives, deliverables, and assigned responsibilities to achieve defined project outcomes.")
SubClassOf(:NFDI_0001035 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001036 (comment textual entity)

AnnotationAssertion(rdfs:label :NFDI_0001036 "comment textual entity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001036 "A comment textual entity is a textual entity that provides supplimentary information, feedback, opinions, clarifications, or annotations related to a specific subject.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001036 "peer review comments on journal articles, user feedback on digital repositories, inline annotations in collaborative documents, explanatory remarks in software code documentation")
SubClassOf(:NFDI_0001036 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001037 (digital object identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001037 "DOI")
AnnotationAssertion(rdfs:label :NFDI_0001037 "digital object identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001037 "A Digital Object Identifier (DOI) is a centrally registered identifier that provides a unique, persistent reference to digital objects such as publications, datasets, and software, ensuring reliable access and citation.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001037 "10.1016/j.compind.2023.104016")
SubClassOf(:NFDI_0001037 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001039 (NFDI consortium)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001039 "National Research Data Infrastructure"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> :NFDI_0001039 "Nationale Forschungsdateninfrastruktur"@de)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001039 "https://www.dfg.de/en/research-funding/funding-initiative/nfdi")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001039 "https://www.nfdi.de/")
AnnotationAssertion(rdfs:label :NFDI_0001039 "NFDI consortium"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001039 "An NFDI Consortium is a collaborative organizational entity within the German National Research Data Infrastructure (NFDI) initiative, responsible for the development, management, and coordination of research data infrastructures in specific scientific domains.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001039 "The National Research Data Infrastructure (NFDI) is intended to sytematically manage scientifich and research data, provide long-term data storage, backup and accessibility, and network the data (inter-)nationally. The German Research Foundation (DFG) and the Joint Science Conference (GWK) are working together to establish and fund the NFDI, on the basis of the administrative agreement concluded by the Federal Government and the federal states on November 26, 2018. The NFDI is designed as a nationwide network, which is built gradually and cooperatively by the respective communities. The goal is to provide a reliable and sustainable service portfolio that covers generic and disciplinary requirements of research data management in Germany. The NFDI is developed step by step and science-oriented with services available to researchers from vaious disciplines, institutions, and federal states.")
SubClassOf(:NFDI_0001039 :NFDI_0000006)

# Class: :NFDI_0001040 (academic title)

AnnotationAssertion(rdfs:label :NFDI_0001040 "academic title"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001040 "An academic title is an identifier that denotes an individual’s academic rank, qualification, or honorary designation within educational and research institutions.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001040 "Professor, Associate Professor, Dr., PhD, Dr. Ing.")
SubClassOf(:NFDI_0001040 <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: :NFDI_0001041 (postal code)

AnnotationAssertion(rdfs:isDefinedBy :NFDI_0001041 "http://purl.obolibrary.org/obo/IAO_0000646")
AnnotationAssertion(rdfs:label :NFDI_0001041 "postal code"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001041 "An identifier that denotes some postal delivery route, some aggregate of postal delivery routes or a geographical region and was created for the purpose of sorting and delivering mail.")
SubClassOf(:NFDI_0001041 <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: :NFDI_0001042 (zone improvement plan code)

AnnotationAssertion(rdfs:isDefinedBy :NFDI_0001042 "http://purl.obolibrary.org/obo/IAO_0000648")
AnnotationAssertion(rdfs:label :NFDI_0001042 "zone improvement plan code"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001042 "A postal code that is used in the United States for the purpose of sorting and delivering mail, and that denotes some postal delivery route or some aggregate of postal delivery routes.")
SubClassOf(:NFDI_0001042 :NFDI_0001041)

# Class: :NFDI_0001043 (meeting)

AnnotationAssertion(rdfs:label :NFDI_0001043 "meeting"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001043 "Av event that brings together individuals or groups for structured discussions, decision-making, planning, or coordination of research, educational, or institutional activities.")
SubClassOf(:NFDI_0001043 :NFDI_0000018)

# Class: :NFDI_0001044 (data analysis software)

AnnotationAssertion(rdfs:label :NFDI_0001044 "data analysis software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001044 "Data Analysis Software is a subclass of Software designed to process, visualize, and interpret structured and unstructured data using statistical, machine learning, and computational techniques.")
SubClassOf(:NFDI_0001044 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001045 (electronic lab notebook)

AnnotationAssertion(rdfs:label :NFDI_0001045 "electronic lab notebook"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001045 "An Electronic Lab Notebook (ELN) is a subclass of Software that provides a digital platform for recording, managing, and sharing experimental procedures, observations, and research data in scientific workflows.")
SubClassOf(:NFDI_0001045 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001046 (image processing software)

AnnotationAssertion(rdfs:label :NFDI_0001046 "image processing software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001046 "Image Processing Software is a subclass of Software that enables the manipulation, enhancement, analysis, and visualization of images obtained from experimental, computational, or simulation-based sources.")
SubClassOf(:NFDI_0001046 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001047 (operating system)

AnnotationAssertion(rdfs:label :NFDI_0001047 "operating system"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001047 "An Operating System (OS) is a software system that manages computer hardware and software resources and provides common services for computer programs. It acts as an intermediary between users and the computer hardware, enabling the execution of application programs.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001047 "Concerning the content of ‘Software’ datasheet and its related knowledge graph, the ‘Operating System’ class wase created to respond to competency questions like what operating systems are compatible with a specific software.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001047 "Windows, Linux, MacOS")
SubClassOf(:NFDI_0001047 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001048 (simulation software)

AnnotationAssertion(rdfs:label :NFDI_0001048 "simulation software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001048 "Simulation Software is a subclass of Software that facilitates the modeling and numerical simulation of physical, chemical, or computational systems to study behaviors, interactions, and performance under different conditions")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001048 "Examples include COMSOL Multiphysics, LAMMPS, Quantum ESPRESSO, and ANSYS.")
SubClassOf(:NFDI_0001048 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001049 (workflow management software)

AnnotationAssertion(rdfs:label :NFDI_0001049 "workflow management software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001049 "Workflow Management Software is a subclass of Software that provides tools for designing, automating, executing, and monitoring scientific or computational workflows in research and engineering domains.")
SubClassOf(:NFDI_0001049 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0001050 (event implementation specification)

AnnotationAssertion(rdfs:label :NFDI_0001050 "event implementation specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001050 "An event implementation specification is a type of Directive Information Entity that provides formal guidelines, constraints, and details on how an event should be executed. It specifies the mode of implementation, including logistical, technical, and procedural aspects required to carry out an event successfully.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001050 "HBN: Concerning the content of ‘Event’ datasheets and its related knowledge graph, the ‘Event Implementation Specification’ class and its instances were created to respond to competency questions like what are the implementation formats of a given event.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001050 "Specifications for organizing conferences, training workshops, and academic seminars in different formats such as virtual, in-person, or hybrid settings.")
EquivalentClasses(:NFDI_0001050 ObjectIntersectionOf(:NFDI_0000203 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> :NFDI_0000131)))
SubClassOf(:NFDI_0001050 :NFDI_0000203)

# Class: :NFDI_0001051 (funding specification)

AnnotationAssertion(rdfs:label :NFDI_0001051 "funding specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001051 "A funding specification is a directive information entity that provides structured guidelines, policies, and requirements for securing, managing, and allocating financial resources for various activities, projects, or organizations.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001051 "HBN: Concerning the content of ‘Service’ datasheets and its related knowledge graph, the ‘Funding Specification’ class and its instances were created to respond to competency questions like what funding models exist for a given service.")
SubClassOf(:NFDI_0001051 :NFDI_0000203)

# Class: :NFDI_0001052 (information access specification)

AnnotationAssertion(rdfs:label :NFDI_0001052 "information access specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001052 "An information access specification is a directive information entity that defines the policies, conditions, and mechanisms governing the accessibility of digital or physical information resources for users or organizations.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001052 "HBN: Concerning the content of ‘Publication’ datasheet and its related knowledge graph, the ‘Information Access Specification’ class and its instances were created to respond to competency questions like: what access policies apply to a specific publication document, which resources are available under open access, etc.")
SubClassOf(:NFDI_0001052 :NFDI_0000203)

# Class: :NFDI_0001053 (ontology version IRI)

AnnotationAssertion(rdfs:label :NFDI_0001053 "ontology version IRI"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001053 "An ontology version IRI is a unique identifier that points to a specific version of an ontology. It helps distinguish between different updates or revisions of the same ontology. This ensures consistent referencing and compatibility across systems using the ontology."@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0001053 "issue: issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/95")
SubClassOf(:NFDI_0001053 <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: :NFDI_0001054 (metadata specification)

AnnotationAssertion(rdfs:label :NFDI_0001054 "metadata specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001054 "A Metadata Specification is a detailed document that describes metadata structures, guidelines, and usage policies for standardization and adoption.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001054 "metadata schema and standards")
SubClassOf(:NFDI_0001054 :NFDI_0000203)

# Class: :NFDI_0001055 (TGN identifier)

AnnotationAssertion(rdfs:label :NFDI_0001055 "TGN identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001055 "The TGN Identifier refers to a unique ID within the Getty Thesaurus of Geographic Names (TGN), which is a controlled vocabulary developed to standardize geographic names for use in cultural heritage and library contexts. The TGN is part of the Getty Vocabulary Program by the Getty Research Institute."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001055 "http://vocab.getty.edu/page/tgn/7003712")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001055 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/100")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001055 "TGN")
SubClassOf(:NFDI_0001055 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001056 (status specification)

AnnotationAssertion(rdfs:label :NFDI_0001056 "status specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001056 "A status specification is a directive information entity that defines the current state, progress, or condition of an entity, process, or project based on predefined criteria and operational guidelines.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001056 "HBN: Concerning the content of ‘Service’ and 'International collabrations' datasheets and their related knowledge graphs, the ‘Status Specification’ class and its instances were created to respond to competency questions like: what is the current status of a service or collaboration project, which collabrations are in an active state, etc.")
SubClassOf(:NFDI_0001056 :NFDI_0000203)

# Class: :NFDI_0001057 (co organizer role)

AnnotationAssertion(rdfs:label :NFDI_0001057 "co organizer role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001057 "A role inherent in an agent that is realized when collaborating in planning, managing, and executing an event, project, or initiative alongside one or more primary organizers."@en)
SubClassOf(:NFDI_0001057 :NFDI_0000229)

# Class: :NFDI_0001058 (co spokesperson role)

AnnotationAssertion(rdfs:label :NFDI_0001058 "co spokesperson role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001058 "A role inherent in an agent that is realized when shareing the responsibilities of representing an organization, group, or initiative, typically communicating its views, policies, or findings to the public."@en)
SubClassOf(:NFDI_0001058 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> :NFDI_0000004)))

# Class: :NFDI_0001059 (collaboration partner role)

AnnotationAssertion(rdfs:label :NFDI_0001059 "collaboration partner role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001059 "A role inherent in an agent that is realized when engageing in cooperative work with another individual or organization toward a shared goal, such as research, development, or business initiatives."@en)
SubClassOf(:NFDI_0001059 :NFDI_0000229)

# Class: :NFDI_0001060 (manufacturer role)

AnnotationAssertion(rdfs:label :NFDI_0001060 "manufacturer role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001060 "A role inherent in an agent that is realized when being responsible for producing goods, components, or materials through industrial or commercial processes."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001060 "Siemens as a manufacturer of industrial automation equipment or Intel as a manufacturer of semiconductor chips")
SubClassOf(:NFDI_0001060 :NFDI_0000229)

# Class: :NFDI_0001061 (organizer role)

AnnotationAssertion(rdfs:label :NFDI_0001061 "organizer role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001061 "A role inherent in an agent that is realized when being responsible for planning, managing, and executing an event, project, or structured activity."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001061 "event management firms organizing scientific symposiums or non-profit organizations coordinating community outreach programs")
SubClassOf(:NFDI_0001061 :NFDI_0000229)

# Class: :NFDI_0001062 (speaker role)

AnnotationAssertion(rdfs:label :NFDI_0001062 "speaker role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001062 "A role inherent in an agent that is realized when delivers presentations, lectures, or speeches at events, conferences, or public gatherings."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001062 "invited speakers at scientific symposiums, keynote presenters at technology expos, and guest lecturers at universities")
SubClassOf(:NFDI_0001062 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> :NFDI_0000004)))

# Class: :NFDI_0001068 (LCNAF identifier)

AnnotationAssertion(rdfs:label :NFDI_0001068 "LCNAF identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001068 "The LCNAF Identifier refers to a unique identifier assigned to entries in the Library of Congress Name Authority File (LCNAF). This file is a standardized authority database maintained by the Library of Congress, used to establish and control the names of people, organizations, geographic places, and titles in bibliographic records."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001068 "http://id.loc.gov/authorities/names/n78095332")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001068 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/101")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001068 "LCNAF")
SubClassOf(:NFDI_0001068 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001069 (BnF identifier)

AnnotationAssertion(rdfs:label :NFDI_0001069 "BnF identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001069 "The BnF Identifier refers to a unique identifier assigned to an authority record in the Bibliothèque nationale de France (BnF) catalog. It is part of the BnF’s authority files, used to standardize names of people, organizations, titles, places, and subjects across bibliographic records."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001069 "https://catalogue.bnf.fr/ark:/12148/cb123735831")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001069 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/102")
AnnotationAssertion(:NFDI_0010015 :NFDI_0001069 "BnF")
SubClassOf(:NFDI_0001069 <http://purl.obolibrary.org/obo/IAO_0000578>)

# Class: :NFDI_0001095 (sparql endpoint)

AnnotationAssertion(rdfs:label :NFDI_0001095 "sparql endpoint"@de)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001095 "A SPARQL Endpoint is a web application software that provides a queryable interface for accessing and retrieving structured data from RDF-based knowledge graphs using the SPARQL query language."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001095 "Wikidata Query Service, DBpedia SPARQL Endpoint, Linked Data Fragments")
SubClassOf(:NFDI_0001095 :NFDI_0000222)

