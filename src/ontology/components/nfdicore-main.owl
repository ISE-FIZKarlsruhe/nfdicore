AnnotationAssertion(rdfs:label :NFDI_0001102 "affiliation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001102 "An affiliation is a textual entity that specifies the organizational or institutional association of an individual, group, or entity, typically used in academic, professional, or research contexts.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001102 "FIZ Karlsruhe – Leibniz-Institute for Information Infrastructure
Karlsruhe Institute of Technology, Institute of Applied Informatics and Formal Description Methods")
SubClassOf(:NFDI_0001102 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001103 (goal textual entity)

AnnotationAssertion(rdfs:label :NFDI_0001103 "goal textual entity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001103 "A goal textual entity is a textual entity that describes the intended objectives, aims, or targets of a project, initiative, organization, or research effort, providing a clear statement of purpose and expected outcomes.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001103 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001103 <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: :NFDI_0001104 (conference abstract)

AnnotationAssertion(rdfs:label :NFDI_0001104 "conference abstract"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001104 "A Conference Abstract is a brief summary of research findings or scholarly work submitted for presentation at an academic or professional conference, often serving as a precursor to a full paper or presentation.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001104 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001104 <http://purl.obolibrary.org/obo/IAO_0000311>)

# Class: :NFDI_0001105 (conference paper)

AnnotationAssertion(rdfs:label :NFDI_0001105 "conference paper"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001105 "A Conference Paper is a scholarly publication that presents research findings at an academic or professional conference, typically published in conference proceedings.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001105 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001105 <http://purl.obolibrary.org/obo/IAO_0000311>)

# Class: :NFDI_0001106 (conference poster)

AnnotationAssertion(rdfs:label :NFDI_0001106 "conference poster"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001106 "A Conference Poster is a visual presentation of research findings, displayed at an academic or professional conference to facilitate discussion and knowledge exchange.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001106 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001106 <http://purl.obolibrary.org/obo/IAO_0000311>)

# Class: :NFDI_0001120 (evaluating process)

AnnotationAssertion(rdfs:label :NFDI_0001120 "evaluating process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001120 "process in which an agent or system applies criteria, standards, or methods to determine the value, quality, correctness, performance, or status of a target entity")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001120 "https://github.com/ISE-FIZKarlsruhe/nfdicore/pull/150")
SubClassOf(:NFDI_0001120 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0001200 (interim report)

AnnotationAssertion(rdfs:label :NFDI_0001200 "interim report"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001200 "An Interim Report is a report that provides a temporary or progress-based assessment of an ongoing project, research, or operational activity, documenting current findings, challenges, and future directions before the final report is completed.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001200 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001200 <http://purl.obolibrary.org/obo/IAO_0000088>)

# Class: :NFDI_0001201 (research data repository)

AnnotationAssertion(rdfs:label :NFDI_0001201 "research data repository"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001201 "A Research Data Repository is a data portal designed for the preservation, management, and sharing of research datasets, ensuring long-term accessibility and compliance with open science principles.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001201 "Open Science Framework (OSF), Harvard Dataverse")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001201 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001201 :NFDI_0000123)

# Class: :NFDI_0001202 (repository hosting data portal)

AnnotationAssertion(rdfs:label :NFDI_0001202 "repository hosting data portal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001202 "A Repository Hosting Data Portal is a data portal that provides infrastructure and tools for hosting datasets, code, and publications in a structured and accessible format.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001202 "Zenodo, Figshare, Dataverse")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001202 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001202 :NFDI_0000123)

# Class: :NFDI_0001203 (experimental dataset)

AnnotationAssertion(rdfs:label :NFDI_0001203 "experimental dataset"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001203 "An Experimental Dataset is a dataset that contains measured or observed data collected from laboratory experiments, physical tests, or scientific investigations.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001203 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001203 <http://purl.obolibrary.org/obo/IAO_0001000>)

# Class: :NFDI_0001204 (reference dataset)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001204 "https://doi.org/10.1016/j.actamat.2025.120735")
AnnotationAssertion(rdfs:label :NFDI_0001204 "reference dataset"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001204 "A Reference Dataset is a dataset that serves as a benchmark or standardized collection of data used for validation, comparison, and reproducibility in scientific research and engineering applications.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001204 "Reference data of materials
- are documented according to certain standards as well as
- are curated (i.e., generated, maintained, preserved, validated) according to certain standards
- are quantitative data sets (i.e., data + their corresponding metadata)
- have been measured or simulated to a particularly high standard, and
- are generated for a material that has either experienced a well-documented process or is reference material
or its composition and structure has been completely characterized.
Reference data of materials can also be derived data from reference data.
These data are distributed with a license (e.g., GPL).
The here addressed standards for documentation, curation and measurement need to be defined for specific
materials characteristics (e.g., creep tests) in terms of domain standards. These domain standards are the
result of a steered community process.
Standards should integrate as much as possible existing standards (e.g., the individual MatWerk domain
standards should be as much as possible consistent).")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001204 "BAM reference data: results of ASTM E139 -11 creep tests on a reference material of Nimonic 75 nickel-base alloy (https://doi.org/10.5281/zenodo.7764161)")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001204 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001204 <http://purl.obolibrary.org/obo/IAO_0001000>)

# Class: :NFDI_0001205 (simulation dataset)

AnnotationAssertion(rdfs:label :NFDI_0001205 "simulation dataset"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001205 "A Simulation Dataset is a dataset that contains data generated from computational models, numerical simulations, or digital twin environments to predict material behaviors, properties, and interactions.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001205 "Examples include DFT simulation datasets, molecular dynamics (MD) trajectory files, and phase-field modeling results.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001205 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001205 <http://purl.obolibrary.org/obo/IAO_0001000>)

# Class: :NFDI_0001206 (large scale facility)

AnnotationAssertion(rdfs:label :NFDI_0001206 "large scale facility"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001206 "A Large-Scale Facility is a service product that provides specialized, high-capacity infrastructure for scientific research, engineering, or computational purposes, supporting large-scale experiments, simulations, and data analysis in various domains.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0001206 "HBN: Concerning the content of ‘Large-Scale Facility’ datasheet and its related knowledge graph, the ‘Large-Scale Facility’ class and its subclasses were created to define the types of used facilituies and respond to competency questions like: what large-scale facilities support research in field X, which organization provide facility Y, what is the contact point with facility Z, etc.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001206 "European Synchrotron Radiation Facility (ESRF), the Leibniz Supercomputing Centre (LRZ), CERN's Large Hadron Collider (LHC)")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001206 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001206 :NFDI_0000232)

# Class: :NFDI_0001207 (presentation document)

AnnotationAssertion(rdfs:label :NFDI_0001207 "presentation document"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001207 "A Presentation Document is a document that consists of structured visual and textual content designed for conveying information to an audience, typically used in meetings, conferences, and educational settings.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001207 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119")
SubClassOf(:NFDI_0001207 <http://purl.obolibrary.org/obo/IAO_0000310>)

