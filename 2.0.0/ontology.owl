        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">technology of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/url -->


    <owl:ObjectProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/url">
