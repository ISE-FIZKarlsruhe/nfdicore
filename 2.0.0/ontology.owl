    <!-- http://nfdi.fiz-karlsruhe.de/ontology/dataset -->


    <owl:ObjectProperty rdf:about="http://nfdi.fiz-karlsruhe.de/ontology/dataset">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
        <owl:inverseOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/datasetOf"/>
        <rdfs:domain rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Resource"/>
        <rdfs:range rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Dataset"/>
        <rdfs:comment xml:lang="en">The property is a relation between a resource and a data set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">data set</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://nfdi.fiz-karlsruhe.de/ontology/part -->


    <owl:ObjectProperty rdf:about="http://nfdi.fiz-karlsruhe.de/ontology/part">
        <owl:inverseOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/partOf"/>
        <rdfs:comment xml:lang="en">The generic property is a relationship between a thing and its part.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">part</rdfs:label>
    </owl:ObjectProperty>
    


