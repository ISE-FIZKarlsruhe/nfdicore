AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000215 "A plan specification that refers to a technology method employed for the creation, management, utilization, or control of a digital resource."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000215 "A technology, e.g. a web application or a programming framework used in a resource."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000215 "Groovy on Grails, Angular"@en)
AnnotationAssertion(:NFDI_0000012 :NFDI_0000215 "TechnologicalMeans")
SubClassOf(:NFDI_0000215 <http://purl.obolibrary.org/obo/IAO_0000104>)

# Class: :NFDI_0000218 (obsolete software application)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000218 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000218 <http://purl.obolibrary.org/obo/IAO_0000594>)
AnnotationAssertion(rdfs:label :NFDI_0000218 "obsolete software application"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0000218 "http://purl.obolibrary.org/obo/IAO_0000594")
AnnotationAssertion(owl:deprecated :NFDI_0000218 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000218 "Software that can be downloaded and executed locally on the users' hardware."@en)

# Class: :NFDI_0000219 (training service)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000219 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000219 "training service"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000219 "Standalone training for self-study can be considered a technical service (usually a web application). Generally speaking, training materials often come in the form of specific measures or tutorials that are attached to a service and that are designed to improve the user’s service experience. Our joint understanding of training as a stand-alone service, however, is not limited to the above and includes materials designed for education in all fields of research data management."@en)
SubClassOf(:NFDI_0000219 :NFDI_0000101)

# Class: :NFDI_0000222 (web application software)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000222 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000222 "web application software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000222 "Software that is installed on a server and can be used by users via a web page and the internet, for example Software-as-a-service (SaaS)."@en)
SubClassOf(:NFDI_0000222 <http://purl.obolibrary.org/obo/IAO_0000010>)

