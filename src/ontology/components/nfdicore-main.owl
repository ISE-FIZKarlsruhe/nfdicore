AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010019 "An event focused on interactive learning, where participants engage in hands-on activities or group work to develop specific skills or knowledge."@en)
SubClassOf(:NFDI_0010019 :NFDI_0000018)

# Class: :NFDI_0010020 (conference)

AnnotationAssertion(rdfs:label :NFDI_0010020 "conference"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010020 "An event where experts and scholars gather to present research, exchange ideas, and discuss advancements in a particular field."@en)
SubClassOf(:NFDI_0010020 :NFDI_0000018)

# Class: :NFDI_0010021 (hackathon)

