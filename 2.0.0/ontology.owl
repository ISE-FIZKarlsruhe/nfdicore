        <rdfs:label xml:lang="en">technology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/technologyOf -->


    <owl:ObjectProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/technologyOf">
