        </rdfs:domain>
        <rdfs:range rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/AcademicDiscipline"/>
        <obo:IAO_0000232>to check for BFO superproperty</obo:IAO_0000232>
        <rdfs:comment xml:lang="en">The property establishes a connection between a resource, an agent, or a project, and the academic discipline, subject area, or domain within which they operate.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">subject area</rdfs:label>
    </owl:ObjectProperty>
    


