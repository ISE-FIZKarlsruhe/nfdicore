                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> <https://nfdi.fiz-karlsruhe.de/ontology/Project> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <https://nfdi.fiz-karlsruhe.de/ontology/p>
                                                                ] ;
