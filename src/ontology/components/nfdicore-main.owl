# Class: :NFDI_0010028 (data handling process)

AnnotationAssertion(rdfs:label :NFDI_0010028 "data handling process"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010028 <http://purl.obolibrary.org/obo/T4FS_0000012>)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010028 "A process that involves the collection, organization, cleaning, analysis, storage, and sharing of data to ensure its accuracy, accessibility, and usefulness for decision-making, research, or other applications. Data handling encompasses all stages from raw data generation to its final visualization or publication.")
SubClassOf(:NFDI_0010028 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0010029 (data producing process)

AnnotationAssertion(rdfs:label :NFDI_0010029 "data producing process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010029 "A data handling process where raw data is generated through experiments, observations, or data collection tools, often as the initial step in the data lifecycle.")
SubClassOf(:NFDI_0010029 :NFDI_0010028)

# Class: :NFDI_0010030 (data processing process)

AnnotationAssertion(rdfs:label :NFDI_0010030 "data processing process"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010030 <http://purl.obolibrary.org/obo/T4FS_0000044>)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010030 "A data handling process where raw data is cleaned, transformed, and analyzed to extract meaningful insights, patterns, or trends.")
SubClassOf(:NFDI_0010030 :NFDI_0010028)

# Class: :NFDI_0010031 (dataset creation process)

AnnotationAssertion(rdfs:label :NFDI_0010031 "dataset creation process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010031 "A data handling process involving the organization and structuring of data into datasets for easier access, analysis, and sharing.")
SubClassOf(:NFDI_0010031 ObjectIntersectionOf(:NFDI_0010028 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000299> <http://purl.obolibrary.org/obo/IAO_0001000>)))

# Class: :NFDI_0010033 (dataset documenting process)

AnnotationAssertion(rdfs:label :NFDI_0010033 "dataset documenting process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010033 "A data handling process where metadata, descriptions, and details about datasets are recorded to ensure clarity, context, and proper usage by others.")
SubClassOf(:NFDI_0010033 :NFDI_0010028)

# Class: :NFDI_0010034 (data cleaning process)

AnnotationAssertion(rdfs:label :NFDI_0010034 "data cleaning process"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010034 <http://purl.obolibrary.org/obo/T4FS_0000384>)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010034 "A data handling process where incorrect, incomplete, or irrelevant data is identified and corrected or removed to improve the quality of the dataset.")
SubClassOf(:NFDI_0010034 :NFDI_0010028)

# Class: :NFDI_0010035 (data transformation process)

AnnotationAssertion(rdfs:label :NFDI_0010035 "data transformation process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010035 "A data handling process involving the conversion of data into a different format, structure, or scale to make it compatible with analysis tools or systems.")
SubClassOf(:NFDI_0010035 :NFDI_0010028)

# Class: :NFDI_0010036 (data integration process)

AnnotationAssertion(rdfs:label :NFDI_0010036 "data integration process"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010036 <http://purl.obolibrary.org/obo/T4FS_0000487>)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010036 "A data handling process where data from multiple sources are combined or merged to create a cohesive and comprehensive dataset for analysis.")
SubClassOf(:NFDI_0010036 :NFDI_0010028)

# Class: :NFDI_0010037 (data storage process)

AnnotationAssertion(rdfs:label :NFDI_0010037 "data storage process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010037 "A data handling process where data is securely stored in databases or other systems, ensuring it can be retrieved and accessed as needed.")
SubClassOf(:NFDI_0010037 :NFDI_0010028)

# Class: :NFDI_0010038 (data visualization process)

AnnotationAssertion(rdfs:label :NFDI_0010038 "data visualization process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010038 "A data handling process where data is represented visually through charts, graphs, or other formats to aid in understanding and decision-making.")
SubClassOf(:NFDI_0010038 :NFDI_0010028)

# Class: :NFDI_0010039 (obsolete software method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0010039 "http://purl.obolibrary.org/obo/IAO_0000591")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0010039 <http://purl.obolibrary.org/obo/IAO_0000591>)
AnnotationAssertion(rdfs:label :NFDI_0010039 "obsolete software method"@en)
AnnotationAssertion(owl:deprecated :NFDI_0010039 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010039 "A software method (also called subroutine, subprogram, procedure, method, function, or routine) is software designed to execute a specific task.")

# Class: :NFDI_0010040 (obsolete software module)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0010040 "http://purl.obolibrary.org/obo/IAO_0000592")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0010040 <http://purl.obolibrary.org/obo/IAO_0000592>)
AnnotationAssertion(rdfs:label :NFDI_0010040 "obsolete software module"@en)
AnnotationAssertion(owl:deprecated :NFDI_0010040 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010040 "A software module is software composed of a collection of software methods.")

# Class: :NFDI_0010041 (obsolete software script)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0010041 "http://purl.obolibrary.org/obo/IAO_0000595")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0010041 <http://purl.obolibrary.org/obo/IAO_0000595>)
AnnotationAssertion(rdfs:label :NFDI_0010041 "obsolete software script"@en)
AnnotationAssertion(owl:deprecated :NFDI_0010041 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010041 "A software script is software whose instructions can be executed using a software interpreter.")


############################
#   Named Individuals
############################

# Individual: :NFDI_0000157 (electrical engineering)

AnnotationAssertion(rdfs:label :NFDI_0000157 "electrical engineering"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0000157 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000157 "An academic discipline that focuses on the study, design, and application of electrical systems and technologies. Electrical engineering involves the development of devices, circuits, and systems for power generation, communication, electronics, and automation.")
ClassAssertion(:NFDI_0000100 :NFDI_0000157)

# Individual: :NFDI_0000159 (process engineering)

AnnotationAssertion(rdfs:label :NFDI_0000159 "process engineering"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0000159 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000159 "An academic discipline that focuses on the design, optimization, and operation of industrial processes to transform raw materials into valuable products. Process engineering applies principles of chemistry, physics, and engineering to improve efficiency, sustainability, and safety in industries such as manufacturing, energy, and pharmaceuticals."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0000159)

# Individual: :NFDI_0001063 (artificial intelligence)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001063 "Russell, S., & Norvig, P. (2020). Artificial Intelligence: A Modern Approach. Pearson.")
AnnotationAssertion(rdfs:label :NFDI_0001063 "artificial intelligence"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001063 "Artificial Intelligence (AI) is a sub-discipline of Computer Science that focuses on creating systems capable of performing tasks that require human-like intelligence, such as learning, reasoning, and problem-solving.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001063 "Deep learning for image recognition, reinforcement learning in robotics, and natural language processing fall under Artificial Intelligence.")
ClassAssertion(:NFDI_0000100 :NFDI_0001063)
ObjectPropertyAssertion(<http://www.w3.org/2004/02/skos/core#broader> :NFDI_0001063 :NFDI_0010017)

# Individual: :NFDI_0001064 (theoretical computer science)

AnnotationAssertion(rdfs:label :NFDI_0001064 "theoretical computer science"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001064 "Theoretical Computer Science is a sub-discipline of Computer Science that focuses on mathematical models of computation, computational complexity, and algorithmic problem-solving")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001064 "Studies on Turing machines, complexity classes (P vs NP), and formal languages belong to Theoretical Computer Science.")
ClassAssertion(:NFDI_0000100 :NFDI_0001064)
ObjectPropertyAssertion(<http://www.w3.org/2004/02/skos/core#broader> :NFDI_0001064 :NFDI_0010017)

# Individual: :NFDI_0001065 (software engineering)

AnnotationAssertion(rdfs:label :NFDI_0001065 "software engineering"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001065 "Software Engineering is a sub-discipline of Computer Science that applies engineering principles to the design, development, testing, and maintenance of software systems.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001065 "Agile software development, DevOps practices, and software architecture design fall under Software Engineering.")
ClassAssertion(:NFDI_0000100 :NFDI_0001065)
ObjectPropertyAssertion(<http://www.w3.org/2004/02/skos/core#broader> :NFDI_0001065 :NFDI_0010017)

# Individual: :NFDI_0001066 (data science)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001066 "Provost, F., & Fawcett, T. (2013). Data Science for Business. O'Reilly Media.")
AnnotationAssertion(rdfs:label :NFDI_0001066 "data science"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001066 "Data Science is a sub-discipline of Computer Science that integrates statistical methods, machine learning, and data processing techniques to extract insights and knowledge from structured and unstructured data.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001066 "Predictive analytics, big data visualization, and recommendation systems are part of Data Science.")
ClassAssertion(:NFDI_0000100 :NFDI_0001066)
ObjectPropertyAssertion(<http://www.w3.org/2004/02/skos/core#broader> :NFDI_0001066 :NFDI_0010017)

# Individual: :NFDI_0001067 (cybersecurity)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0001067 "Stallings, W. (2020). Network Security Essentials. Pearson.")
AnnotationAssertion(rdfs:label :NFDI_0001067 "cybersecurity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001067 "Cybersecurity is a sub-discipline of Computer Science that focuses on protecting computer systems, networks, and data from cyber threats, vulnerabilities, and unauthorized access.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001067 "Encryption techniques, intrusion detection systems, and ethical hacking studies belong to Cybersecurity.")
ClassAssertion(:NFDI_0000100 :NFDI_0001067)
ObjectPropertyAssertion(<http://www.w3.org/2004/02/skos/core#broader> :NFDI_0001067 :NFDI_0010017)

# Individual: :NFDI_0001070 (active status)

AnnotationAssertion(rdfs:label :NFDI_0001070 "active status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001070 "Active Status is a status specification that indicates an entity, process, or project is currently operational, ongoing, or in execution.")
ClassAssertion(:NFDI_0001056 :NFDI_0001070)

# Individual: :NFDI_0001071 (cancelled status)

AnnotationAssertion(rdfs:label :NFDI_0001071 "cancelled status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001071 "Cancelled Status is a status specification that indicates an entity, process, or project has been terminated before reaching completion due to internal or external factors.")
ClassAssertion(:NFDI_0001056 :NFDI_0001071)

# Individual: :NFDI_0001072 (Dr.)

AnnotationAssertion(rdfs:label :NFDI_0001072 "Dr."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001072 "Doctor (PhD or equivalent academic doctorate)")
ClassAssertion(:NFDI_0001040 :NFDI_0001072)

# Individual: :NFDI_0001073 (Dr.-Ing.)

AnnotationAssertion(rdfs:label :NFDI_0001073 "Dr.-Ing."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001073 "Doctor of Engineering (German doctorate in engineering).")
ClassAssertion(:NFDI_0001040 :NFDI_0001073)

# Individual: :NFDI_0001074 (finished status)

AnnotationAssertion(rdfs:label :NFDI_0001074 "finished status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001074 "Finished Status is a status specification that indicates an entity, process, or project has successfully reached its intended goal and is considered complete.")
ClassAssertion(:NFDI_0001056 :NFDI_0001074)

# Individual: :NFDI_0001075 (hybrid implementation)

AnnotationAssertion(rdfs:label :NFDI_0001075 "hybrid implementation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001075 "Hybrid Implementation is an event implementation specification that defines the organization of an event that integrates both physical (on-site) and virtual (online) participation modes")
ClassAssertion(:NFDI_0001050 :NFDI_0001075)

# Individual: :NFDI_0001076 (internal access)

AnnotationAssertion(rdfs:label :NFDI_0001076 "internal access"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001076 "Internal Access is an information access specification that defines policies and mechanisms restricting access to information exclusively within an organization, institution, or research group.")
ClassAssertion(:NFDI_0001052 :NFDI_0001076)

# Individual: :NFDI_0001077 (M.Sc.)

AnnotationAssertion(rdfs:label :NFDI_0001077 "M.Sc."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001077 "Master of Science (graduate degree in science/engineering).")
ClassAssertion(:NFDI_0001040 :NFDI_0001077)

# Individual: :NFDI_0001078 (on site implementation)

AnnotationAssertion(rdfs:label :NFDI_0001078 "on site implementation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001078 "On-Site Implementation is an event implementation specification that defines the organization of an event that occurs exclusively at a physical location with in-person attendance.")
ClassAssertion(:NFDI_0001050 :NFDI_0001078)

# Individual: :NFDI_0001079 (online implementation)

AnnotationAssertion(rdfs:label :NFDI_0001079 "online implementation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001079 "Online Implementation is an event implementation specification that defines the organization of an event conducted entirely through virtual platforms, enabling remote participation via digital communication technologies.")
ClassAssertion(:NFDI_0001050 :NFDI_0001079)

# Individual: :NFDI_0001080 (open access)

AnnotationAssertion(rdfs:label :NFDI_0001080 "open access"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001080 "Open Access is an information access specification that defines policies allowing unrestricted public access to information resources, ensuring free availability without subscription or payment barriers.")
ClassAssertion(:NFDI_0001052 :NFDI_0001080)

# Individual: :NFDI_0001081 (organizational funding)

AnnotationAssertion(rdfs:label :NFDI_0001081 "organizational funding"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001081 "Organizational Funding is a funding specification that defines the financial structures, budgets, and resource allocation strategies for sustaining the operations of an organization or institution.")
ClassAssertion(:NFDI_0001051 :NFDI_0001081)

# Individual: :NFDI_0001082 (paused status)

AnnotationAssertion(rdfs:label :NFDI_0001082 "paused status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001082 "Paused Status is a status specification that indicates an entity, process, or project is temporarily halted but may resume at a later stage.")
ClassAssertion(:NFDI_0001056 :NFDI_0001082)

# Individual: :NFDI_0001083 (paywall access)

AnnotationAssertion(rdfs:label :NFDI_0001083 "paywall access"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001083 "Paywall Access is an information access specification that defines policies requiring users to purchase, subscribe, or obtain institutional licenses to access digital or physical information resources.")
ClassAssertion(:NFDI_0001052 :NFDI_0001083)

# Individual: :NFDI_0001084 (PD. Dr.)

AnnotationAssertion(rdfs:label :NFDI_0001084 "PD. Dr."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001084 "Privatdozent (Dr. with habilitation, qualified to teach at a university)")
ClassAssertion(:NFDI_0001040 :NFDI_0001084)

# Individual: :NFDI_0001085 (PD. Dr. habil.)

AnnotationAssertion(rdfs:label :NFDI_0001085 "PD. Dr. habil."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001085 "Privatdozent with Habilitation (higher academic qualification in Germany)")
ClassAssertion(:NFDI_0001040 :NFDI_0001085)

# Individual: :NFDI_0001086 (planning status)

AnnotationAssertion(rdfs:label :NFDI_0001086 "planning status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001086 "Planning Status is a status specification that indicates an entity, process, or project is in a preparatory or strategic development phase before execution.")
ClassAssertion(:NFDI_0001056 :NFDI_0001086)

# Individual: :NFDI_0001087 (Prof.)

AnnotationAssertion(rdfs:label :NFDI_0001087 "Prof."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001087 "Professor (academic title for a senior faculty member).")
ClassAssertion(:NFDI_0001040 :NFDI_0001087)

# Individual: :NFDI_0001088 (Prof. Dr.)

AnnotationAssertion(rdfs:label :NFDI_0001088 "Prof. Dr."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001088 "Professor with a doctorate.")
ClassAssertion(:NFDI_0001040 :NFDI_0001088)

# Individual: :NFDI_0001089 (Prof. Dr.-Ing.)

AnnotationAssertion(rdfs:label :NFDI_0001089 "Prof. Dr.-Ing."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001089 "Professor with a doctorate in engineering.")
ClassAssertion(:NFDI_0001040 :NFDI_0001089)

# Individual: :NFDI_0001090 (project funding)

AnnotationAssertion(rdfs:label :NFDI_0001090 "project funding"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001090 "Project Funding is a funding specification that defines the financial mechanisms, grants, and investment strategies used to support specific research, development, or innovation projects.")
ClassAssertion(:NFDI_0001051 :NFDI_0001090)

# Individual: :NFDI_0001091 (restricted access)

AnnotationAssertion(rdfs:label :NFDI_0001091 "restricted access"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001091 "Restricted Access is an information access specification that defines policies limiting access to specific users, organizations, or groups based on predefined criteria such as confidentiality, security, or legal regulations.")
ClassAssertion(:NFDI_0001052 :NFDI_0001091)

# Individual: :NFDI_0001092 (self funding)

AnnotationAssertion(rdfs:label :NFDI_0001092 "self funding"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001092 "Self-Funding is a funding specification that defines the use of personal, internal, or independently generated financial resources to support activities, projects, or organizations without relying on external funding sources.")
ClassAssertion(:NFDI_0001051 :NFDI_0001092)

# Individual: :NFDI_0001093 (test phase status)

AnnotationAssertion(rdfs:label :NFDI_0001093 "test phase status"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001093 "Test Phase Status is a status specification that indicates an entity, process, or project is undergoing testing, evaluation, or validation before finalization.")
ClassAssertion(:NFDI_0001056 :NFDI_0001093)

# Individual: :NFDI_0001094 (Dr. Dr.)

AnnotationAssertion(rdfs:label :NFDI_0001094 "Dr. Dr."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001094 "Two Doctor degrees (PhD or equivalent academic doctorate)"@en)
ClassAssertion(:NFDI_0001040 :NFDI_0001094)

# Individual: :NFDI_0010001 (humanity)

AnnotationAssertion(rdfs:label :NFDI_0010001 "humanity"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010001 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010001 "An academic discipline focused on human culture, thought, and creativity, encompassing disciplines like literature, philosophy, and the arts."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010001)

# Individual: :NFDI_0010002 (social science)

AnnotationAssertion(rdfs:label :NFDI_0010002 "social science"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010002 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010002 "An academic discipline that studies society and human behavior through disciplines like sociology, psychology, and economics."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010002)

# Individual: :NFDI_0010004 (biology)

AnnotationAssertion(rdfs:label :NFDI_0010004 "biology"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010004 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010004 "An academic discipline that studies living organisms, their structures, functions, growth, and interactions with their environment. Biology explores the diversity of life, from microscopic organisms to complex ecosystems, and seeks to understand the underlying processes of life, evolution, and heredity."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010004)

# Individual: :NFDI_0010005 (medicine)

AnnotationAssertion(rdfs:label :NFDI_0010005 "medicine"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010005 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010005 "An academic discipline that focuses on the science and practice of diagnosing, treating, and preventing illnesses and injuries. Medicine involves the study of human health, medical technologies, pharmaceuticals, and patient care to improve well-being and extend life."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010005)

# Individual: :NFDI_0010006 (agriculture)

AnnotationAssertion(rdfs:label :NFDI_0010006 "agriculture"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010006 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010006 "An academic discipline that focuses on the science, practice, and business of cultivating plants, raising animals, and producing food, fiber, and other products. Agriculture involves the study of soil management, crop production, livestock care, and sustainable farming practices to ensure food security and environmental sustainability."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010006)

# Individual: :NFDI_0010007 (natural science)

AnnotationAssertion(rdfs:label :NFDI_0010007 "natural science"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010007 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010007 "An academic discipline that studies the natural world through observation, experimentation, and analysis. Natural science includes fields such as physics, chemistry, biology, and earth sciences, aiming to understand the laws and processes governing the universe and life on Earth.")
ClassAssertion(:NFDI_0000100 :NFDI_0010007)

# Individual: :NFDI_0010008 (chemistry)

AnnotationAssertion(rdfs:label :NFDI_0010008 "chemistry"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010008 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010008 "An academic discipline that studies the composition, structure, properties, and reactions of matter. Chemistry focuses on understanding how substances interact, transform, and combine to form new materials, playing a crucial role in fields such as medicine, energy, and environmental science."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010008)

# Individual: :NFDI_0010010 (physics)

AnnotationAssertion(rdfs:label :NFDI_0010010 "physics"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010010 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010010 "An academic discipline that explores the fundamental principles governing the behavior of matter, energy, and the forces of nature. Physics seeks to understand the laws of the universe, from subatomic particles to cosmic phenomena, through experimentation, observation, and mathematical modeling."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010010)

# Individual: :NFDI_0010011 (mathematics)

AnnotationAssertion(rdfs:label :NFDI_0010011 "mathematics"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010011 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010011 "An academic discipline that involves the study of numbers, quantities, shapes, and patterns, using abstract concepts and logical reasoning. Mathematics is fundamental to various fields, including science, engineering, economics, and technology, providing tools for problem-solving, analysis, and modeling.")
ClassAssertion(:NFDI_0000100 :NFDI_0010011)

# Individual: :NFDI_0010012 (geoscience)

AnnotationAssertion(rdfs:label :NFDI_0010012 "geoscience"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010012 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010012 "An academic discipline that focuses on the study of the Earth’s structure, processes, and materials, including the atmosphere, oceans, and landforms. Geoscience encompasses fields such as geology, meteorology, and environmental science to understand Earth’s history, natural resources, and natural hazards."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010012)

# Individual: :NFDI_0010014 (mechanical engineering)

AnnotationAssertion(rdfs:label :NFDI_0010014 "mechanical engineering"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010014 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010014 "An academic discipline that focuses on the design, analysis, manufacturing, and maintenance of mechanical systems. Mechanical engineering applies principles of physics, materials science, and mathematics to develop machines, tools, and devices used in industries such as transportation, energy, and robotics."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010014)

# Individual: :NFDI_0010016 (materials science)

AnnotationAssertion(rdfs:label :NFDI_0010016 "materials science"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010016 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010016 "An academic discipline that explores the properties, performance, and applications of materials, focusing on the relationship between a material's structure and its characteristics. Materials science and engineering involves the design, development, and testing of materials for use in a wide range of industries, including aerospace, electronics, and manufacturing."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010016)

# Individual: :NFDI_0010017 (computer science)

AnnotationAssertion(rdfs:label :NFDI_0010017 "computer science"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010017 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010017 "An academic discipline that focuses on the study of algorithms, data structures, programming, and computational systems. Computer science explores how to design, develop, and analyze software and hardware solutions to solve complex problems and advance technology."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010017)

# Individual: :NFDI_0010018 (construction engineering)

AnnotationAssertion(rdfs:label :NFDI_0010018 "construction engineering"@en)
AnnotationAssertion(rdfs:seeAlso :NFDI_0010018 "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010018 "An academic discipline that focuses on the planning, design, and management of construction projects, including buildings, infrastructure, and other structures. Construction engineering integrates principles of civil engineering, project management, and materials science to ensure safety, efficiency, and sustainability in construction processes."@en)
ClassAssertion(:NFDI_0000100 :NFDI_0010018)


