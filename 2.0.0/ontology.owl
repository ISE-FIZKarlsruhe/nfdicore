        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">end date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://nfdi.fiz-karlsruhe.de/ontology/startDate -->


    <owl:DatatypeProperty rdf:about="http://nfdi.fiz-karlsruhe.de/ontology/startDate">
        <rdfs:domain rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The property refers to the moment in time when an event begins.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">start date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/dissolutionDate -->


    <owl:DatatypeProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/dissolutionDate">
