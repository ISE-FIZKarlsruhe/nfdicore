SubClassOf(:NFDI_0000223 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000030> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002353> :NFDI_0000224)))

# Class: :NFDI_0000224 (creative process)

AnnotationAssertion(rdfs:label :NFDI_0000224 "creative process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000224 "A process that involves generating, developing, and refining original ideas or concepts through exploration, experimentation, and problem-solving, aiming to produce innovative or expressive outcomes in artistic, scientific, or other creative fields."@en)
SubClassOf(:NFDI_0000224 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000015> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> :NFDI_0000004)))

# Class: :NFDI_0000227 (workflow process)

AnnotationAssertion(rdfs:label :NFDI_0000227 "workflow process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000227 "A process that processes tasks, activities, or steps to achieve specific objectives efficiently within an organized workflow system."@en)
SubClassOf(:NFDI_0000227 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000015> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000055> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0000260> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000059> :NFDI_0001002)))))

# Class: :NFDI_0000228 (service product role)

AnnotationAssertion(rdfs:label :NFDI_0000228 "service product role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000228 "Role of an immaterial entity that facilitates the delivery or support of a service product, ensuring its proper execution and value realization."@en)
SubClassOf(:NFDI_0000228 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000023> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> :NFDI_0000101)))

# Class: :NFDI_0000229 (agent role)

AnnotationAssertion(rdfs:label :NFDI_0000229 "agent role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000229 "Role of an independent continuant that is realized through an agent's actions, enabling the agent to perform specific functions or achieve particular outcomes within a system or context."@en)
SubClassOf(:NFDI_0000229 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000023> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> :NFDI_0000102)))

# Class: :NFDI_0000230 (service provider role)

AnnotationAssertion(rdfs:label :NFDI_0000230 "service provider role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000230 "A role inherent in an agent that is realized when delivering services, managing processes, and ensuring the effective fulfillment of service product requirements."@en)
SubClassOf(:NFDI_0000230 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> :NFDI_0000101)))

# Class: :NFDI_0000232 (service product)

AnnotationAssertion(rdfs:label :NFDI_0000232 "service product"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000232 "An immaterial entity that provides value through a service offering, delivering intangible benefits or functionality designed to fulfill specific needs or requirements, often in a structured process."@en)
SubClassOf(:NFDI_0000232 <http://purl.obolibrary.org/obo/BFO_0000141>)

# Class: :NFDI_0000244 (service specification)

AnnotationAssertion(rdfs:label :NFDI_0000244 "service specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000244 "A plan specification that defines the requirements, features, and parameters of a service, outlining its scope, performance, and delivery criteria."@en)
SubClassOf(:NFDI_0000244 <http://purl.obolibrary.org/obo/IAO_0000104>)

# Class: :NFDI_0001000 (software title)

AnnotationAssertion(rdfs:label :NFDI_0001000 "software title"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001000 "A textual entity that uniquely identifies a specific software application, program, or system, often used for branding, categorization, and reference in documentation, licensing, and distribution.")
SubClassOf(:NFDI_0001000 ObjectIntersectionOf(:NFDI_0001019 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> <http://purl.obolibrary.org/obo/IAO_0000010>)))

# Class: :NFDI_0001001 (citation)

