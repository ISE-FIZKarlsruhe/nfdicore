AnnotationAssertion(owl:deprecated :NFDI_0000198 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000198 "A plan specification that comprises a set of instructions, programs, or algorithms designed to perform specific tasks or functions on a computer or other electronic devices."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000198 "A computer software provided by an organization or a person."@en)
