# Class: :NFDI_0000203 (specification)

AnnotationAssertion(rdfs:label :NFDI_0000203 "specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000203 "A directive information entity that defines the requirements, characteristics, or standards for the design, implementation, or operation of a system, product, or process.Specification is a set of requirements, guidelines, standards contributed by an organization or a person."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000203 "2024-03-24. Sasha Bruns: specifications have dual nature - they are both directive information entities guiding actions (plan specification) and digital intellectual resources providing relevant information and guidelines (creative work)."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000203 "Guidelines, technical specifications, design specifications"@en)
SubClassOf(:NFDI_0000203 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000033> ObjectSomeValuesFrom(ObjectInverseOf(<http://purl.obolibrary.org/obo/RO_0002234>) :NFDI_0000224)))

# Class: :NFDI_0000206 (standard)

AnnotationAssertion(rdfs:label :NFDI_0000206 "standard"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000206 "A specification that establishes a set of guidelines, criteria, or norms recognized and adopted by internationational community."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000206 "An international standard and norm that can be used to evaluate or create a resource."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000206 "ISO 15511, DINI-Zertifikat")
SubClassOf(:NFDI_0000206 :NFDI_0000203)

# Class: :NFDI_0000210 (storage service)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000210 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000210 "storage service"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000210 "Provision of storage space for research data as a service to external users. Access is possible via web protocols."@en)
