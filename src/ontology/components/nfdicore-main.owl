# Class: :NFDI_0000214 (support service)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000214 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000214 "support service"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000214 "Service with direct user contact for topics going beyond the support for specific single services."@en)
SubClassOf(:NFDI_0000214 :NFDI_0000101)

