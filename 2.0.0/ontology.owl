        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The property refers to the date on which the organization ceased to exist or was formally dissolved.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">dissolution date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/emailAddress -->


    <owl:DatatypeProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/emailAddress">
