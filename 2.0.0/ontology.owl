        </rdfs:domain>
        <rdfs:range rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Country"/>
        <rdfs:comment xml:lang="en">The property relates a city or a state to a country where it is located.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">country</rdfs:label>
    </owl:ObjectProperty>
    


