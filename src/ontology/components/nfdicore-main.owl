############################
#   Annotation Properties
############################

# Annotation Property: :NFDI_0000012 (readable IRI label)

AnnotationAssertion(rdfs:label :NFDI_0000012 "readable IRI label"@en)
SubAnnotationPropertyOf(:NFDI_0000012 <http://purl.obolibrary.org/obo/IAO_0000118>)

# Annotation Property: :NFDI_0010013 (term tracker annotation)

AnnotationAssertion(rdfs:label :NFDI_0010013 "term tracker annotation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010013 "A term tracker annotation is an editor note used to track the history of an entity. For each change, it records the related GitHub issue and pull request.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0010013 "adapted from http://openenergy-platform.org/ontology/oeo/OEO_00020426")

# Annotation Property: :NFDI_0010015 (has acronym)

AnnotationAssertion(rdfs:label :NFDI_0010015 "has acronym"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0010015 "A relation between an entity and its abbreviated form, representing a shortened version of the original term or phrase.")
SubAnnotationPropertyOf(:NFDI_0010015 <http://purl.obolibrary.org/obo/IAO_0000118>)


############################
#   Object Properties
############################

# Object Property: <http://purl.obolibrary.org/obo/IAO_0000136> (is about)

InverseObjectProperties(<http://purl.obolibrary.org/obo/IAO_0000136> :NFDI_0000226)

# Object Property: <http://purl.obolibrary.org/obo/IAO_0000235> (denoted by)

SubObjectPropertyOf(<http://purl.obolibrary.org/obo/IAO_0000235> :NFDI_0000226)

# Object Property: <http://purl.obolibrary.org/obo/RO_0002233> (has input)

SubObjectPropertyOf(<http://purl.obolibrary.org/obo/RO_0002233> <http://purl.obolibrary.org/obo/RO_0000057>)
InverseObjectProperties(<http://purl.obolibrary.org/obo/RO_0002233> <http://purl.obolibrary.org/obo/RO_0002352>)

# Object Property: <http://purl.obolibrary.org/obo/RO_0002234> (has output)

SubObjectPropertyOf(<http://purl.obolibrary.org/obo/RO_0002234> <http://purl.obolibrary.org/obo/RO_0000057>)
InverseObjectProperties(<http://purl.obolibrary.org/obo/RO_0002234> <http://purl.obolibrary.org/obo/RO_0002353>)

# Object Property: <http://purl.obolibrary.org/obo/RO_0002352> (input of)

SubObjectPropertyOf(<http://purl.obolibrary.org/obo/RO_0002352> <http://purl.obolibrary.org/obo/RO_0000056>)

# Object Property: <http://purl.obolibrary.org/obo/RO_0002353> (output of)

SubObjectPropertyOf(<http://purl.obolibrary.org/obo/RO_0002353> <http://purl.obolibrary.org/obo/RO_0000056>)

# Object Property: :NFDI_0000226 (is subject of)

AnnotationAssertion(rdfs:label :NFDI_0000226 "is subject of"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> :NFDI_0000226 "is described by")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000226 "inverse of the relation 'is about'")


############################
#   Data Properties
############################

# Data Property: :NFDI_0001007 (has value)

AnnotationAssertion(rdfs:label :NFDI_0001007 "has value"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001007 "A relation between an information content entity and its specific value."@en)

# Data Property: :NFDI_0001008 (has url)

AnnotationAssertion(rdfs:label :NFDI_0001008 "has url"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001008 "A relation between an information content entity and its specific url."@en)
DataPropertyRange(:NFDI_0001008 xsd:anyURI)



############################
#   Classes
############################

# Class: <http://purl.obolibrary.org/obo/IAO_0000300> (textual entity)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://purl.obolibrary.org/obo/IAO_0000300> "Words, sentences, paragraphs, and the written (non-figure) parts of publications are all textual entities"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/IAO_0000300> "A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/IAO_0000300> "AR, (IAO call 2009-09-01): a document as a whole is not typically a textual entity, because it has pictures in it - rather there are parts of it that are textual entities. Examples: The title, paragraph 2 sentence 7, etc."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/IAO_0000300> "MC, 2009-09-14 (following IAO call 2009-09-01): textual entities live at the FRBR (http://en.wikipedia.org/wiki/Functional_Requirements_for_Bibliographic_Records) manifestation level. Everything is significant: line break, pdf and html versions of same document are different textual entities."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://purl.obolibrary.org/obo/IAO_0000300> "text"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/IAO_0000300> "textual entity"@en)
SubClassOf(<http://purl.obolibrary.org/obo/IAO_0000300> <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: <http://purl.obolibrary.org/obo/IAO_0020016> (given name)

SubClassOf(<http://purl.obolibrary.org/obo/IAO_0020016> <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: <http://purl.obolibrary.org/obo/IAO_8000001> (base ontology module)

SubClassOf(<http://purl.obolibrary.org/obo/IAO_8000001> :NFDI_0000024)

# Class: <http://purl.obolibrary.org/obo/IAO_8000003> (main release ontology module)

SubClassOf(<http://purl.obolibrary.org/obo/IAO_8000003> :NFDI_0000024)

# Class: <http://purl.obolibrary.org/obo/IAO_8000013> (reasoned ontology module)

SubClassOf(<http://purl.obolibrary.org/obo/IAO_8000013> :NFDI_0000024)

# Class: <http://purl.obolibrary.org/obo/OBI_0000245> (organization)

SubClassOf(<http://purl.obolibrary.org/obo/OBI_0000245> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000040> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> :NFDI_0000229)))

# Class: :NFDI_0000001 (obsolete NFDI resource)

AnnotationAssertion(rdfs:label :NFDI_0000001 "obsolete NFDI resource"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000001 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000001 "An information content entity that refers to digital creative works and services, and is utilized to organize the resources of NFDI. The most generic kind of a resource and may be associated with any kind of digital creative work, e.g. datasets, collections, metadata; offered products and services, e.g. data portals, data curation, data digitization."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000001 "2024-03-25 - Sasha Bruns: 
This class is useful in nfdicore to provide a unified and structured representation of the diverse range of resources that contribute to the NFDI infrastructure. IMO,  it helps to emphasize the scope of resources that can be contributed to the NFDI compared to all information content entites in IAO."@en)
AnnotationAssertion(:NFDI_0000012 :NFDI_0000001 "Resource")
AnnotationAssertion(:NFDI_0010013 :NFDI_0000001 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/118")

# Class: :NFDI_0000002 (project)

AnnotationAssertion(rdfs:label :NFDI_0000002 "project"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000002 "A process of a scientific or business endeavor that aims to conclude an investigation or to answer a research question."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000002 "Why \"project\" as an occurrent:
- A project typically has a start and end time.
- It involves a sequence of activities, such as planning, conducting experiments, analyzing data, and publishing results.
- It has temporal parts (e.g., Phase 1, Phase 2, review stages).
So, it aligns well with the occurrent category - more precisely, it can be considered a complex process made up of various subprocesses.

But what about the organization or plan behind it?
- The institution running or participating the project would be a continuant (consortium).
- The project plan might be a generically dependent continuant (a kind of information content entity).
- But the project as executed over time is an occurrent."@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0000002 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/50")
SubClassOf(:NFDI_0000002 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0000004 (person)

AnnotationAssertion(rdfs:label :NFDI_0000004 "person"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000004 "An object that represents a single human individual."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000004 "2024-03-24. Sasha Bruns - the class is not mapped to NCBITaxon_9606 (homo sapiens) due to different scope of the ontologies. \"Person\" in nfdicore represents entities with specific roles, responsibilities, and attributes within an organization, and is not limited to its biological characteristics."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000004 "Harald Sack, Tabea Tietz, Sasha Bruns, Etienne Posthumus")
SubClassOf(:NFDI_0000004 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000030> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> :NFDI_0000229)))

# Class: :NFDI_0000005 (place)

AnnotationAssertion(rdfs:label :NFDI_0000005 "place"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000005 "A site that refers to geographical locations, such as cities, countries, landmarks, and natural environments."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000005 "A spatial region, e.g. country, city or district."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000005 "Hessen, Berlin, Schweiz")
AnnotationAssertion(:NFDI_0010013 :NFDI_0000005 "Issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/75")
SubClassOf(:NFDI_0000005 <http://purl.obolibrary.org/obo/BFO_0000029>)

# Class: :NFDI_0000006 (consortium)

AnnotationAssertion(rdfs:label :NFDI_0000006 "consortium"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000006 "An organisation that consists of multiple independent groups and individuals, who join together to collaborate on a specific goal."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000006 "A consortium of autonomous organizations collaborating towards a shared goal, operating within the framework of an agreement."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000006 "NFDI4Culture, NFDI-MatWerk, DataPLANT.")
SubClassOf(:NFDI_0000006 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0000245> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002351> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> :NFDI_0000110))))

# Class: :NFDI_0000008 (obsolete creative work)

AnnotationAssertion(rdfs:label :NFDI_0000008 "obsolete creative work"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000008 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000008 "An independent continuant or information content entity that refers to a manifestation of someone's creative effort. A creative work refers to a digital intellectual or artistic resource, e.g. a dataset, metadata, a guideline, a software and other materials offering relevant information or instructions within their specific domains."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000008 "2024-03-22. Sasha Bruns - Unlike schema:CreativeWork, nfdicore:CreativeWork is specialized to cover digital creative works only. Through the mapping to \"schema:CreativeWork and 'information content entity'\", we exclude material creative works such as real paintings, architectural objects, and other physical artifacts, which fall outside the scope of nfdicore:CreativeWork."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000008 "TRANSRAZ Data Model, NFDI4Culture Knowledge Graph, Guide for digital collection management at art museums, NFDI4Culture SPARQL Endpoint, Registry for Tools & Services, RADAR4Culture service, etc.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0000008 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/122")

# Class: :NFDI_0000009 (obsolete dataset)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000009 <http://purl.obolibrary.org/obo/IAO_0001000>)
AnnotationAssertion(rdfs:label :NFDI_0000009 "obsolete dataset"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000009 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000009 "An information content entity that refers to a structured collection of data, organized typically for a specific goal such as analysis, research, or reference. Dataset is structured information about a resource provided by an organization or a person."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000009 "2024-04-10. Sasha Bruns: nfdicore:dataset and ioa:data set are not equivalent, due to their differing conceptualizations of what constitutes a iao:data item, which is a superclass of iao:data set. In the nfdicore ontology, a dataset may not necessarily align perfectly with the definition of a data item, since this definition implies a level of accuracy that may not always apply to datasets in their entirety. While a nfdicore:dataset may contain data items, it doesn't necessarily qualify as a data item itself under the strict definition provided by ioa:dataset. This differentiation helps us avoid ambiguity and ensures that our modeling aligns with the intended semantics."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000009 "Fotothek Bibliotheca Hertziana Max-Planck-Institut für Kunstgeschichte 320px static derivates research dataset (https://doi.org/10.17617/3.SVH2BT)")

# Class: :NFDI_0000011 (obsolete plan)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000011 <http://purl.obolibrary.org/obo/OBI_0000260>)
AnnotationAssertion(rdfs:label :NFDI_0000011 "obsolete plan"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000011 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000011 "A realizable entity that represents a structured set of intended actions or steps designed to achieve specific objectives or outcomes."@en)

# Class: :NFDI_0000014 (obsolete publishing process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000014 "http://purl.obolibrary.org/obo/IAO_0000444")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000014 <http://purl.obolibrary.org/obo/IAO_0000444>)
AnnotationAssertion(rdfs:label :NFDI_0000014 "obsolete publishing process"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000014 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000014 "A process of making information, such as literature, music, and software etc., available to the public for sale or for free."@en)

# Class: :NFDI_0000015 (obsolete identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000015 "http://purl.obolibrary.org/obo/IAO_0020000")
AnnotationAssertion(rdfs:label :NFDI_0000015 "obsolete identifier"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000015 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000015 "An information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity.")

# Class: :NFDI_0000016 (software development)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000016 "http://purl.obolibrary.org/obo/APOLLO_SV_00000008")
AnnotationAssertion(rdfs:label :NFDI_0000016 "software development"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000016 "A process that has specified output a software product and that involves the creation of source code."@en)
SubClassOf(:NFDI_0000016 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0000017 (spokesperson role)

AnnotationAssertion(rdfs:label :NFDI_0000017 "spokesperson role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000017 "A role inherent in an agent that is realized when representing, advocating, or communicating on behalf of an organization or group to convey messages or information."@en)
SubClassOf(:NFDI_0000017 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> :NFDI_0000004)))

# Class: :NFDI_0000018 (academic event)

AnnotationAssertion(rdfs:label :NFDI_0000018 "academic event"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000018 "An event that focuses on scholarly activities and the exchange of knowledge, typically involving presentations, discussions, or collaborations among researchers, academics, and students, often in the context of conferences, workshops, seminars, symposia, or colloquia, to advance a specific field of study or interdisciplinary research."@en)
SubClassOf(:NFDI_0000018 ObjectIntersectionOf(:NFDI_0000131 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> :NFDI_0000019))))

# Class: :NFDI_0000019 (academic organization role)

AnnotationAssertion(rdfs:label :NFDI_0000019 "academic organization role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000019 "A role inherent in an organization that is realized when coordinating, managing, or supporting academic activities, programs, or research to promote education and knowledge advancement."@en)
SubClassOf(:NFDI_0000019 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> <http://purl.obolibrary.org/obo/OBI_0000245>)))

# Class: :NFDI_0000020 (industry organization role)

AnnotationAssertion(rdfs:label :NFDI_0000020 "industry organization role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000020 "A role inherent in an organization that is realized when promoting, regulating, or supporting industry-specific standards, practices, and collaboration to advance sector development and innovation."@en)
SubClassOf(:NFDI_0000020 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> <http://purl.obolibrary.org/obo/OBI_0000245>)))

# Class: :NFDI_0000021 (obsolete workflow)

AnnotationAssertion(rdfs:label :NFDI_0000021 "obsolete workflow"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000021 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000021 "A plan that specifies a sequence of tasks, processes, or operations, often involving multiple agents, tools, or systems, to achieve a specific goal or produce a desired outcome."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000021 "A workflow defines the logical order and dependencies of steps, the roles or entities responsible for each step, and the inputs and outputs required for and produced by each task. It is a realizable entity that can be enacted or executed within a defined context, such as a business process, computational framework, or organizational procedure.")
AnnotationAssertion(:NFDI_0010013 :NFDI_0000021 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/125")

# Class: :NFDI_0000022 (obsolete document)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> :NFDI_0000022 "A journal article, patent application, laboratory notebook, or a book")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000022 "http://purl.obolibrary.org/obo/IAO_0000310")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000022 <http://purl.obolibrary.org/obo/IAO_0000310>)
AnnotationAssertion(rdfs:label :NFDI_0000022 "obsolete document"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000022 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000022 "A collection of information content entities intended to be understood together as a whole"@en)

# Class: :NFDI_0000023 (ontology)

AnnotationAssertion(rdfs:label :NFDI_0000023 "ontology"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000023 "An (nfdi) ontology is a data item that coherently represents all components of an ontology, including its versions, variants, modules and other associated artifacts. It is typically denoted by a name and/or an acronym, which is the term we use to communicate about it."@en)
SubClassOf(:NFDI_0000023 <http://purl.obolibrary.org/obo/IAO_0000027>)

# Class: :NFDI_0000024 (ontology variant)

AnnotationAssertion(rdfs:label :NFDI_0000024 "ontology variant"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000024 "An ontology variant represents a self-contained, reusable subset of an ontology that provides a specific functionality while maintaining interoperability with the larger ontology. Typically, an ontology is released in different variants, which makes a variant a release artifact."@en)
SubClassOf(:NFDI_0000024 <http://purl.obolibrary.org/obo/IAO_8000000>)

# Class: :NFDI_0000025 (patent)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> :NFDI_0000025 "US Patent 6,449,603")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000025 "http://purl.obolibrary.org/obo/IAO_0000313")
AnnotationAssertion(rdfs:label :NFDI_0000025 "patent"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000025 "A document that has been accepted by a patent authority"@en)
SubClassOf(:NFDI_0000025 <http://purl.obolibrary.org/obo/IAO_0000310>)

# Class: :NFDI_0000026 (ontology release version)

AnnotationAssertion(rdfs:label :NFDI_0000026 "ontology release version"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000026 "An (nfdi) ontology release version represents a particular release of an ontology."@en)
SubClassOf(:NFDI_0000026 <http://purl.obolibrary.org/obo/IAO_0000027>)

# Class: :NFDI_0000027 (file data item)

AnnotationAssertion(rdfs:label :NFDI_0000027 "file data item"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000027 "A file data item is a data item that represents a file stored on a hard drive. It might also include essential attributes like its name, location, download URL, size, type, and timestamps for creation, modification, and access. It might also capture permissions and ownership details to control how the file can be accessed or modified."@en)
SubClassOf(:NFDI_0000027 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0000027> ObjectSomeValuesFrom(:NFDI_0000226 <http://purl.obolibrary.org/obo/IAO_0000098>)))

# Class: :NFDI_0000029 (obsolete report)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> :NFDI_0000029 <http://purl.obolibrary.org/obo/IAO_0000088>)
AnnotationAssertion(rdfs:label :NFDI_0000029 "obsolete report"@en)
AnnotationAssertion(owl:deprecated :NFDI_0000029 "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000029 "A document that conveys information, data, or findings, typically structured in a formal or semi-formal manner, to communicate the results of an analysis, investigation, observation, or activity.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000029 "A report is created with the intent of informing specific audiences and may include textual descriptions, visualizations, metrics, or conclusions. It is a realizable entity that is produced and maintained as part of a process or workflow.")

# Class: :NFDI_0000030 (source code repository)

AnnotationAssertion(rdfs:label :NFDI_0000030 "source code repository"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000030 "A document that organizes and stores source code files, associated metadata, and version history to facilitate the management, sharing, and collaborative development of software projects. It serves as a structured collection of information that tracks changes, maintains integrity, and supports workflows such as version control, branching, and merging.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000030 "The source code repository stands for the CONTENT of the repository, which, e.g., you can copy to your hard drive. This distinguishes it from the website class which e.g. is used to publish the content."@en)
SubClassOf(:NFDI_0000030 <http://purl.obolibrary.org/obo/IAO_0000310>)

# Class: :NFDI_0000100 (academic discipline)

AnnotationAssertion(rdfs:label :NFDI_0000100 "academic discipline"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000100 "An information content entity that specifies the subject area, domain or academic discipline of an entity. An academic discipline, a research field or domain of an entity, e.g. a domain of a data portal or a field of study of a person."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000100 "2024-03-26: SB & JW: Following the OMIT Ontology, the academy discilpine is defined as a subclass of bfo:quality (see e.g. http://purl.obolibrary.org/obo/OMIT_0001008)"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000100 "2024-12-16: TT & JW: An academic discipline is not a quality, as assumed before, but an ICE. A discipline like philosophy or chemistry consists of structured knowledge, theories, and practices. These are abstract entities that represent and encode information."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000100 <https://www.wikidata.org/entity/Q12271>)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000100 "Architecture, Art History, Musicology, Media Studies, Performing Arts"@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0000100 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/80"@en)
SubClassOf(:NFDI_0000100 <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: :NFDI_0000101 (service process)

AnnotationAssertion(rdfs:label :NFDI_0000101 "service process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000101 "A process that organizes activities and resources to deliver a specific service, ensuring its efficiency, reliability, and alignment with intended goals."@en)
AnnotationAssertion(:NFDI_0010013 :NFDI_0000101 "Issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/75")
SubClassOf(:NFDI_0000101 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000015> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002234> :NFDI_0000232)))

# Class: :NFDI_0000102 (agent)

AnnotationAssertion(rdfs:label :NFDI_0000102 "agent"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000102 "An independent continuant that acts autonomously and is entrusted with the authority to represent, negotiate, or act on behalf of another agent."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000102 "A class that represents entities that are capable of autonomous actions, decision-making, or interaction within a given environment, e.g. persons or organizations."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000102 "Torsten Schrade, Linnaea Söhn, Academy of Sciences and Literature Mainz"@en)
EquivalentClasses(:NFDI_0000102 ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000004> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> :NFDI_0000229)))

# Class: :NFDI_0000106 (city)

AnnotationAssertion(rdfs:label :NFDI_0000106 "city"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000106 "A place that refers to a densely populated urban area."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000106 "A city or a town where the thing is located."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000106 "Berlin, Hannover, Kyiv"@en)
SubClassOf(:NFDI_0000106 :NFDI_0000005)

# Class: :NFDI_0000107 (collection)

AnnotationAssertion(rdfs:label :NFDI_0000107 "collection"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000107 "A material entity that represents a collection of material entities intended to be understood together as a whole."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000107 "A tangible collection of valuables published or curated by an organization or a person."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000107 "A collection of arts displayed at the museum"@en)
SubClassOf(:NFDI_0000107 <http://purl.obolibrary.org/obo/BFO_0000027>)

# Class: :NFDI_0000110 (consortium member role)

AnnotationAssertion(rdfs:label :NFDI_0000110 "consortium member role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000110 "A role inherent in an organization that is realized when the organization is a member of a consortium."@en)
EquivalentClasses(:NFDI_0000110 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> :NFDI_0000002) ObjectAllValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> <http://purl.obolibrary.org/obo/OBI_0000245>)))

# Class: :NFDI_0000111 (contacting process)

AnnotationAssertion(rdfs:label :NFDI_0000111 "contacting process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000111 "A process in which the contact information of an entity is provided."@en)
AnnotationAssertion(:NFDI_0000012 :NFDI_0000111 "Contacting")
SubClassOf(:NFDI_0000111 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0000114 (contact point role)

AnnotationAssertion(rdfs:label :NFDI_0000114 "contact point role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000114 "A role inherent in an agent that is realized when the agent is a contact point of a resource or a project."@en)
SubClassOf(:NFDI_0000114 :NFDI_0000229)

# Class: :NFDI_0000115 (contributing process)

AnnotationAssertion(rdfs:label :NFDI_0000115 "contributing process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000115 "A process of contibuting or providing information to an endeavor."@en)
AnnotationAssertion(:NFDI_0000012 :NFDI_0000115 "Contributing")
SubClassOf(:NFDI_0000115 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0000118 (contributor role)

AnnotationAssertion(rdfs:label :NFDI_0000118 "contributor role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000118 "A role inherent in an agent that provides input, resources, or effort to support or enhance a project, work, or process."@en)
EquivalentClasses(:NFDI_0000118 ObjectIntersectionOf(:NFDI_0000229 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> :NFDI_0000115) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000081> ObjectIntersectionOf(:NFDI_0000102 ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000056> :NFDI_0000115)))))
SubClassOf(:NFDI_0000118 :NFDI_0000229)

# Class: :NFDI_0000119 (country)

AnnotationAssertion(rdfs:label :NFDI_0000119 "country"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000119 "A place that refers to a defined geographical area distinguished by its territorial boundaries, governance structure, and sovereignty."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000119 "A country where the thing is located."@en)
SubClassOf(:NFDI_0000119 :NFDI_0000005)

# Class: :NFDI_0000121 (database software)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000121 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000121 "database software"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000121 "Software that provides large amounts of structured data from repositories and archives to the user. Usually the data can be uploaded, accessed, searched and/or downloaded via a web browser."@en)
SubClassOf(:NFDI_0000121 <http://purl.obolibrary.org/obo/IAO_0000010>)

# Class: :NFDI_0000122 (data curation service)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> :NFDI_0000122 <https://doi.org/10.5281/zenodo.10101412>)
AnnotationAssertion(rdfs:label :NFDI_0000122 "data curation service"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000122 "The activity of managing and promoting the use of data from their point of creation to ensure that they are fit for contemporary purpose and available for discovery and reuse. For dynamic datasets this may mean continuous enrichment or updating to keep them fit for purpose. Higher levels of curation will also involve links with annotation and with other published materials"@en)
SubClassOf(:NFDI_0000122 :NFDI_0000101)

# Class: :NFDI_0000123 (data portal)

AnnotationAssertion(rdfs:label :NFDI_0000123 "data portal"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000123 "A website that serves as a centralized platform for accessing, managing, and sharing datasets, information, or resources related to a specific topic, theme, or domain."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000123 "An online platform that provides access to datasets."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000123 "Bach digital, KultSam, MusiXplora"@en)
SubClassOf(:NFDI_0000123 :NFDI_0000223)

# Class: :NFDI_0000131 (event)

AnnotationAssertion(rdfs:label :NFDI_0000131 "event"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000131 "An process that represents an organized happening that unfolds in time."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000131 "A class that represents entities that occur or unfold in time, typically characterized by a specific organized happening or occurrence with temporal properties."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000131 "conferences, celebrations, workshops, meetings, or any other specific incident or happening that has been planned somehow."@en)
SubClassOf(:NFDI_0000131 <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: :NFDI_0000134 (federal state)

AnnotationAssertion(rdfs:label :NFDI_0000134 "federal state"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000134 "A place that refers to a geographical territory forming part of a country."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#editorialNote> :NFDI_0000134 "A federal state where the thing is located."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0000134 "Sachsen, Berlin"@de)
SubClassOf(:NFDI_0000134 :NFDI_0000005)

# Class: :NFDI_0000139 (funding organization role)

AnnotationAssertion(rdfs:label :NFDI_0000139 "funding organization role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0000139 "A role inherent in an organization that is realized when the organization serves as a funder to endevaours, e.g. projects."@en)
