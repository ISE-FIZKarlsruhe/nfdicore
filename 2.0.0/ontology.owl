        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <owl:inverseOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/countryOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
