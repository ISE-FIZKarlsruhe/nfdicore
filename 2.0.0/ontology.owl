        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The property relates an agent to their email address.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">email address</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/fileExtension -->


    <owl:DatatypeProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/fileExtension">
        <rdfs:domain rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Resource"/>
        <rdfs:comment xml:lang="en">An identifier for a file format (e.g. txt for a text file) used as a suffix to the file name, don&apos;t use dot at start.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label>file extension</rdfs:label>
        <skos:example>mp4</skos:example>
        <skos:example>ttl</skos:example>
        <skos:example>txt</skos:example>
        <skos:example>xml</skos:example>
    </owl:DatatypeProperty>
    


    <!-- https://nfdi.fiz-karlsruhe.de/ontology/foundationDate -->


    <owl:DatatypeProperty rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/foundationDate">
        <rdfs:domain rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The property refers to the specific date on which the organization was officially established or founded.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/2.0.0"/>
        <rdfs:label xml:lang="en">foundation date</rdfs:label>
    </owl:DatatypeProperty>
    


