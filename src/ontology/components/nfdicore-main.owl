AnnotationAssertion(rdfs:label :NFDI_0001208 "laboratory"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :NFDI_0001208 "A place that provides a controlled environment equipped with specialized instruments and facilities for conducting scientific research, experiments, measurements, and testing across various disciplines.")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> :NFDI_0001208 "materials characterization laboratories, chemical analysis labs, high-energy physics laboratories")
AnnotationAssertion(:NFDI_0010013 :NFDI_0001208 "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/119
https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/120")
SubClassOf(:NFDI_0001208 :NFDI_0000005)

